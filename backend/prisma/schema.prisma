generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model City {
  id          String    @id @default(cuid())
  name        String    @unique
  latitude    Float
  longitude   Float
  createdAt   DateTime  @default(now())

  weather     Weather[]
}

model Weather {
  id        String   @id @default(cuid())

  cityId    String

  day       Int

  date      DateTime

  min       Float
  max       Float
  wind      Float

  isStale   Boolean

  createdAt DateTime @default(now())

  city City @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([cityId, day])
}
